<mujoco model="x3plus_pick_and_place">
  <compiler angle="radian" meshdir="../urdf/meshes"/>
  <option timestep="0.002" gravity="0 0 -9.81" integrator="implicitfast"
          cone="elliptic" iterations="200" tolerance="1e-10"/>
  <size nconmax="200" njmax="600"/>

  <visual>
    <quality shadowsize="4096" offsamples="8"/>
    <global offwidth="1920" offheight="1080" elevation="-15" azimuth="135"/>
    <map znear="0.01" zfar="50" shadowclip="1.0"/>
    <rgba haze="0.15 0.2 0.3 1"/>
    <headlight diffuse="0.15 0.15 0.18" ambient="0.12 0.12 0.14" specular="0.1 0.1 0.1"/>
  </visual>

  <default>
    <joint damping="2.0" armature="0.01"/>
    <geom condim="4" friction="1 0.5 0.01" solref="0.005 1" solimp="0.95 0.99 0.001"/>
    <position kp="200"/>
  </default>

  <asset>
    <texture name="skybox" type="skybox" builtin="gradient"
             rgb1="0.35 0.45 0.65" rgb2="0.08 0.10 0.16"
             width="512" height="3072" mark="random" markrgb="0.6 0.6 0.7"/>
    <texture name="texplane" type="2d" builtin="checker"
             rgb1="0.28 0.28 0.30" rgb2="0.20 0.20 0.22" width="512" height="512"/>
    <texture name="textable" type="2d" builtin="flat"
             rgb1="0.42 0.30 0.18" rgb2="0.50 0.36 0.22" width="512" height="512"
             mark="random" markrgb="0.38 0.26 0.15"/>

    <material name="matplane" texture="texplane" texrepeat="10 10"
              reflectance="0.15" specular="0.2" shininess="0.1"/>
    <material name="mat_green" rgba="0.18 0.62 0.22 1"
              specular="0.5" shininess="0.4" reflectance="0.05"/>
    <material name="mat_gray" rgba="0.72 0.72 0.74 1"
              specular="0.6" shininess="0.5" reflectance="0.08"/>
    <material name="mat_red" rgba="0.88 0.12 0.10 1"
              specular="0.7" shininess="0.6" reflectance="0.1" emission="0.08"/>
    <material name="mat_yellow" rgba="0.95 0.85 0.10 1"
              specular="0.7" shininess="0.6" reflectance="0.1" emission="0.08"/>
    <material name="mat_table" texture="textable" texrepeat="2 2"
              specular="0.3" shininess="0.2" reflectance="0.05"/>

    <mesh name="base_link_visual" file="X3plus/visual/base_link.STL"/>
    <mesh name="arm_link1_visual" file="X3plus/visual/arm_link1.STL"/>
    <mesh name="arm_link2_visual" file="X3plus/visual/arm_link2.STL"/>
    <mesh name="arm_link3_visual" file="X3plus/visual/arm_link3.STL"/>
    <mesh name="arm_link4_visual" file="X3plus/visual/arm_link4.STL"/>
    <mesh name="arm_link5_visual" file="X3plus/visual/arm_link5.STL"/>
    <mesh name="rlink1_visual" file="X3plus/visual/rlink1.STL"/>
    <mesh name="rlink2_visual" file="X3plus/visual/rlink2.STL"/>
    <mesh name="rlink3_visual" file="X3plus/visual/rlink3.STL"/>
    <mesh name="llink1_visual" file="X3plus/visual/llink1.STL"/>
    <mesh name="llink2_visual" file="X3plus/visual/llink2.STL"/>
    <mesh name="llink3_visual" file="X3plus/visual/llink3.STL"/>
    <mesh name="camera_link_visual" file="sensor/visual/camera_link.STL"/>
    <mesh name="laser_link_visual" file="sensor/visual/laser_link.STL"/>
    <mesh name="mono_link_visual" file="sensor/visual/mono_link.STL"/>

    <mesh name="base_link_collision" file="X3plus/collision/base_link.STL"/>
    <mesh name="arm_link1_collision" file="X3plus/collision/arm_link1.STL"/>
    <mesh name="arm_link2_collision" file="X3plus/collision/arm_link2.STL"/>
    <mesh name="arm_link3_collision" file="X3plus/collision/arm_link3.STL"/>
    <mesh name="arm_link4_collision" file="X3plus/collision/arm_link4.STL"/>
    <mesh name="arm_link5_collision" file="X3plus/collision/arm_link5.STL"/>
    <mesh name="rlink1_collision" file="X3plus/collision/rlink1.STL"/>
    <mesh name="rlink2_collision" file="X3plus/collision/rlink2.STL"/>
    <mesh name="rlink3_collision" file="X3plus/collision/rlink3.STL"/>
    <mesh name="llink1_collision" file="X3plus/collision/llink1.STL"/>
    <mesh name="llink2_collision" file="X3plus/collision/llink2.STL"/>
    <mesh name="llink3_collision" file="X3plus/collision/llink3.STL"/>
    <mesh name="camera_link_collision" file="sensor/collision/camera_link.STL"/>
    <mesh name="laser_link_collision" file="sensor/collision/laser_link.STL"/>
    <mesh name="mono_link_collision" file="sensor/collision/mono_link.STL"/>
  </asset>

  <worldbody>
    <!-- Key light (warm, strong, casts shadows) -->
    <light pos="0.5 -0.6 1.8" dir="-0.2 0.3 -1" diffuse="0.85 0.80 0.72"
           specular="0.5 0.5 0.5" castshadow="true" cutoff="60"/>
    <!-- Fill light (cool, softer, no shadows) -->
    <light pos="-0.5 0.5 1.4" dir="0.2 -0.2 -1" diffuse="0.35 0.38 0.45"
           specular="0.15 0.15 0.2" castshadow="false"/>
    <!-- Rim / back light (highlights edges) -->
    <light pos="-0.1 -0.6 1.6" dir="0.05 0.35 -1" diffuse="0.25 0.25 0.30"
           specular="0.3 0.3 0.35" castshadow="true" cutoff="70"/>
    <!-- Overhead ambient fill -->
    <light pos="0.0 0.0 2.5" dir="0 0 -1" diffuse="0.18 0.18 0.22"
           specular="0.05 0.05 0.05" castshadow="false"/>

    <geom name="floor" type="plane" size="3.0 3.0 0.1" material="matplane"/>

    <camera name="front_cam" pos="0.50 -0.38 0.78"
            xyaxes="0.52 0.854 0 -0.32 0.19 0.928" fovy="50"/>

    <!-- ====== Table ====== -->
    <body name="table" pos="0 0 0.35">
      <geom name="table_top" type="box" size="0.3 0.3 0.02" material="mat_table" mass="20"
            contype="1" conaffinity="1" friction="3 0.5 0.01"/>
      <geom name="leg1" type="cylinder" fromto="-0.25 -0.25 -0.35 -0.25 -0.25 -0.02" size="0.02" material="mat_table"
            contype="1" conaffinity="1"/>
      <geom name="leg2" type="cylinder" fromto=" 0.25 -0.25 -0.35  0.25 -0.25 -0.02" size="0.02" material="mat_table"
            contype="1" conaffinity="1"/>
      <geom name="leg3" type="cylinder" fromto="-0.25  0.25 -0.35 -0.25  0.25 -0.02" size="0.02" material="mat_table"
            contype="1" conaffinity="1"/>
      <geom name="leg4" type="cylinder" fromto=" 0.25  0.25 -0.35  0.25  0.25 -0.02" size="0.02" material="mat_table"
            contype="1" conaffinity="1"/>
    </body>

    <!-- ====== Yellow block (to be picked up) ====== -->
    <body name="yellow_block" pos="0.12 0.06 0.384">
      <freejoint name="yellow_joint"/>
      <geom name="yellow_geom" type="box" size="0.012 0.012 0.014" mass="0.02"
            material="mat_yellow" friction="5 0.5 0.01" condim="6"
            solref="0.005 1" solimp="0.95 0.99 0.001"/>
    </body>

    <!-- ====== Red block (place target) ====== -->
    <body name="red_block" pos="0.12 -0.06 0.384">
      <freejoint name="red_joint"/>
      <geom name="red_geom" type="box" size="0.012 0.012 0.014" mass="0.02"
            material="mat_red" friction="3 0.1 0.01" condim="4"
            solref="0.01 1" solimp="0.95 0.99 0.001"/>
    </body>

    <!-- ====== X3Plus robot (mounted on table surface) ======
         STL meshes from urdf/meshes/X3plus/ matching the real hardware.
         Kinematic chain from x3plus.urdf.
    -->
    <body name="base_link" pos="-0.05 0 0.451">
      <geom name="base_link_visual" type="mesh" mesh="base_link_visual"
            material="mat_green" contype="0" conaffinity="0"/>
      <geom name="base_link_collision" type="mesh" mesh="base_link_collision"
            group="3" mass="1.075" contype="0" conaffinity="0"/>

      <!-- Depth camera (fixed on base) -->
      <body name="camera_link" pos="-0.043645 0 0.41955">
        <geom name="camera_link_visual" type="mesh" mesh="camera_link_visual"
              material="mat_gray" contype="0" conaffinity="0"/>
        <geom name="camera_link_collision" type="mesh" mesh="camera_link_collision"
              group="3" mass="0.224" contype="0" conaffinity="0"/>
      </body>

      <!-- Lidar (fixed on base) -->
      <body name="laser_link" pos="0.10478 0 0.0471">
        <geom name="laser_link_visual" type="mesh" mesh="laser_link_visual"
              material="mat_gray" contype="0" conaffinity="0"/>
        <geom name="laser_link_collision" type="mesh" mesh="laser_link_collision"
              group="3" mass="0.043" contype="0" conaffinity="0"/>
      </body>

      <body name="arm_link1" pos="0.09825 0 0.102">
        <joint name="arm_joint1" type="hinge" axis="0 0 -1"
               range="-1.5708 1.5708" damping="1.0"/>
        <geom name="arm_link1_visual" type="mesh" mesh="arm_link1_visual"
              material="mat_gray" contype="0" conaffinity="0"/>
        <geom name="arm_link1_collision" type="mesh" mesh="arm_link1_collision"
              group="3" mass="0.028" contype="1" conaffinity="1"/>

        <body name="arm_link2" pos="0 0 0.0405" euler="-1.5708 0 0">
          <joint name="arm_joint2" type="hinge" axis="0 0 -1"
                 range="-1.5708 1.5708" damping="1.0"/>
          <geom name="arm_link2_visual" type="mesh" mesh="arm_link2_visual"
                material="mat_green" contype="0" conaffinity="0"/>
          <geom name="arm_link2_collision" type="mesh" mesh="arm_link2_collision"
                group="3" mass="0.032" contype="1" conaffinity="1"/>

          <body name="arm_link3" pos="0 -0.0829 0">
            <joint name="arm_joint3" type="hinge" axis="0 0 -1"
                   range="-1.5708 1.5708" damping="1.0"/>
            <geom name="arm_link3_visual" type="mesh" mesh="arm_link3_visual"
                  material="mat_gray" contype="0" conaffinity="0"/>
            <geom name="arm_link3_collision" type="mesh" mesh="arm_link3_collision"
                  group="3" mass="0.032" contype="1" conaffinity="1"/>

            <body name="arm_link4" pos="0 -0.0829 0">
              <joint name="arm_joint4" type="hinge" axis="0 0 -1"
                     range="-1.5708 1.5708" damping="1.0"/>
              <geom name="arm_link4_visual" type="mesh" mesh="arm_link4_visual"
                    material="mat_green" contype="0" conaffinity="0"/>
              <geom name="arm_link4_collision" type="mesh" mesh="arm_link4_collision"
                    group="3" mass="0.050" contype="1" conaffinity="1"/>

              <!-- Wrist camera -->
              <camera name="wrist_cam" pos="-0.0481 -0.05145 -0.0022"
                      euler="1.5708 0 0" fovy="70"/>

              <!-- Wrist camera mount (mono_link, fixed on arm_link4) -->
              <body name="mono_link" pos="-0.0481 -0.05145 -0.0022" euler="1.5708 0 0">
                <geom name="mono_link_visual" type="mesh" mesh="mono_link_visual"
                      material="mat_gray" contype="0" conaffinity="0"/>
                <geom name="mono_link_collision" type="mesh" mesh="mono_link_collision"
                      group="3" mass="0.0098" contype="0" conaffinity="0"/>
              </body>

              <body name="arm_link5" pos="-0.00215 -0.17455 0" euler="1.5708 0 0">
                <joint name="arm_joint5" type="hinge" axis="0 0 1"
                       range="-1.5708 3.14159" damping="0.5"/>
                <geom name="arm_link5_visual" type="mesh" mesh="arm_link5_visual"
                      material="mat_gray" contype="0" conaffinity="0"/>
                <geom name="arm_link5_collision" type="mesh" mesh="arm_link5_collision"
                      group="3" mass="0.041" friction="1 0.5 0.01"/>

                <!-- Right finger: rlink1 (actuated) -> rlink2 (mimic) -->
                <body name="rlink1" pos="-0.0035 -0.012625 -0.0685" euler="0 -1.5708 0">
                  <joint name="grip_joint" type="hinge" axis="0 0 1"
                         range="-1.54 0" damping="5.0"/>
                  <geom name="rlink1_visual" type="mesh" mesh="rlink1_visual"
                        material="mat_green" contype="0" conaffinity="0"/>
                  <geom name="rlink1_collision" type="mesh" mesh="rlink1_collision"
                        group="3" mass="0.00118" friction="3 0.1 0.01"
                        contype="1" conaffinity="1" condim="4"/>

                  <body name="rlink2" pos="0.03 -0.00075429 0">
                    <joint name="rlink_joint2" type="hinge" axis="0 0 1" damping="0.3"/>
                    <geom name="rlink2_visual" type="mesh" mesh="rlink2_visual"
                          material="mat_green" contype="0" conaffinity="0"/>
                    <geom name="rlink2_collision" type="mesh" mesh="rlink2_collision"
                          group="3" mass="0.00245" friction="3 0.1 0.01"
                          contype="1" conaffinity="1" condim="4"/>
                    <geom name="rlink2_pad" type="box" pos="0.030 0.012 0"
                          size="0.010 0.003 0.006" friction="5 0.5 0.01"
                          contype="1" conaffinity="1" condim="6"
                          rgba="0.18 0.62 0.22 1" group="0"/>
                  </body>
                </body>

                <!-- Right linkage bar (rlink3, child of arm_link5) -->
                <body name="rlink3" pos="-0.0035 -0.0045 -0.0505" euler="0 -1.5708 0">
                  <joint name="rlink_joint3" type="hinge" axis="0 0 1" damping="0.3"/>
                  <geom name="rlink3_visual" type="mesh" mesh="rlink3_visual"
                        material="mat_green" contype="0" conaffinity="0"/>
                  <geom name="rlink3_collision" type="mesh" mesh="rlink3_collision"
                        group="3" mass="0.00088" contype="0" conaffinity="0"/>
                </body>

                <!-- Left finger: llink1 (mimic) -> llink2 (mimic) -->
                <body name="llink1" pos="-0.0035 0.012375 -0.0685" euler="0 -1.5708 0">
                  <joint name="llink_joint1" type="hinge" axis="0 0 1" damping="0.3"/>
                  <geom name="llink1_visual" type="mesh" mesh="llink1_visual"
                        material="mat_green" contype="0" conaffinity="0"/>
                  <geom name="llink1_collision" type="mesh" mesh="llink1_collision"
                        group="3" mass="0.00121" friction="3 0.1 0.01"
                        contype="1" conaffinity="1" condim="4"/>

                  <body name="llink2" pos="0.03 0.00065104 0">
                    <joint name="llink_joint2" type="hinge" axis="0 0 1" damping="0.3"/>
                    <geom name="llink2_visual" type="mesh" mesh="llink2_visual"
                          material="mat_green" contype="0" conaffinity="0"/>
                    <geom name="llink2_collision" type="mesh" mesh="llink2_collision"
                          group="3" mass="0.00245" friction="3 0.1 0.01"
                          contype="1" conaffinity="1" condim="4"/>
                    <geom name="llink2_pad" type="box" pos="0.030 -0.012 0"
                          size="0.010 0.003 0.006" friction="5 0.1 0.01"
                          contype="1" conaffinity="1" condim="4"
                          rgba="0.18 0.62 0.22 1" group="0"/>
                  </body>
                </body>

                <!-- Left linkage bar (llink3, child of arm_link5) -->
                <body name="llink3" pos="-0.0035 0.0045 -0.0505" euler="0 -1.5708 0">
                  <joint name="llink_joint3" type="hinge" axis="0 0 1" damping="0.3"/>
                  <geom name="llink3_visual" type="mesh" mesh="llink3_visual"
                        material="mat_green" contype="0" conaffinity="0"/>
                  <geom name="llink3_collision" type="mesh" mesh="llink3_collision"
                        group="3" mass="0.00088" contype="0" conaffinity="0"/>
                </body>

              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <contact>
    <!-- Robot base is bolted to table — suppress interpenetration forces -->
    <exclude body1="base_link" body2="table"/>

    <!-- Adjacent arm links (parent-child self-collision) -->
    <exclude body1="base_link" body2="arm_link1"/>
    <exclude body1="arm_link1" body2="arm_link2"/>
    <exclude body1="arm_link2" body2="arm_link3"/>
    <exclude body1="arm_link3" body2="arm_link4"/>
    <exclude body1="arm_link4" body2="arm_link5"/>

    <!-- Gripper internal linkage (4-bar mechanism) -->
    <exclude body1="arm_link5" body2="rlink1"/>
    <exclude body1="arm_link5" body2="rlink2"/>
    <exclude body1="arm_link5" body2="rlink3"/>
    <exclude body1="arm_link5" body2="llink1"/>
    <exclude body1="arm_link5" body2="llink2"/>
    <exclude body1="arm_link5" body2="llink3"/>
    <exclude body1="rlink1" body2="rlink3"/>
    <exclude body1="llink1" body2="llink3"/>
    <exclude body1="rlink1" body2="llink1"/>
    <exclude body1="rlink1" body2="llink2"/>
    <exclude body1="rlink2" body2="llink1"/>
    <exclude body1="rlink2" body2="llink2"/>
    <exclude body1="rlink3" body2="llink3"/>

    <!-- Sensors mounted on base/arm — no collision needed between them and parent -->
    <exclude body1="base_link" body2="camera_link"/>
    <exclude body1="base_link" body2="laser_link"/>
    <exclude body1="arm_link4" body2="mono_link"/>
  </contact>

  <!-- Gripper equality constraints (4-bar parallel linkage from URDF mimic joints) -->
  <equality>
    <joint joint1="grip_joint" joint2="llink_joint1" polycoef="0 -1 0 0 0"/>
    <joint joint1="grip_joint" joint2="rlink_joint2" polycoef="0 -1 0 0 0"/>
    <joint joint1="grip_joint" joint2="rlink_joint3" polycoef="0 1 0 0 0"/>
    <joint joint1="grip_joint" joint2="llink_joint2" polycoef="0 1 0 0 0"/>
    <joint joint1="grip_joint" joint2="llink_joint3" polycoef="0 -1 0 0 0"/>
  </equality>

  <keyframe>
    <!-- qpos order: yellow_joint(7) red_joint(7) arm1..5 grip rlink2 rlink3 llink1 llink2 llink3 -->
    <key name="init"
         qpos="0.12 0.06 0.384 1 0 0 0
               0.12 -0.06 0.384 1 0 0 0
               0 0.52 1.05 1.57 0 -1.54 1.54 -1.54 -1.54 1.54 1.54"
         ctrl="0 0.52 1.05 1.57 0 -1.54"/>
  </keyframe>

  <actuator>
    <position name="act_joint1" joint="arm_joint1" kp="800" ctrlrange="-1.5708 1.5708"/>
    <position name="act_joint2" joint="arm_joint2" kp="800" ctrlrange="-1.5708 1.5708"/>
    <position name="act_joint3" joint="arm_joint3" kp="800" ctrlrange="-1.5708 1.5708"/>
    <position name="act_joint4" joint="arm_joint4" kp="800" ctrlrange="-1.5708 1.5708"/>
    <position name="act_joint5" joint="arm_joint5" kp="400" ctrlrange="-1.5708 3.14159"/>
    <position name="act_grip"   joint="grip_joint" kp="50" ctrlrange="-1.54 0"
              forcerange="-5 5"/>
  </actuator>
</mujoco>
